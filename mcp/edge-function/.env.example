# =============================================================================
# Shadow MCP Server — Environment Variables
# Copy to .env.local and fill in real values before running locally.
# NEVER commit .env.local to version control.
# =============================================================================

# --- Supabase JWT verification ---
# The HS256 secret from your Supabase project dashboard (Settings > API > JWT Secret).
# Used to verify tokens issued by Supabase Auth.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# --- OAuth 2.1 / JWKS verification ---
# URL of the JWKS endpoint for RS256/ES256 token verification.
# For Supabase-issued JWTs this is typically the Supabase project auth URL.
# Example: https://<project-ref>.supabase.co/auth/v1/jwks
JWKS_URL=https://<project-ref>.supabase.co/auth/v1/jwks

# --- Audience claim expected in access tokens ---
# REQUIRED on the OAuth path. Server fails closed if unset.
# MUST be the MCP server's own audience (e.g. https://mcp.calming-paws.com),
# NOT Supabase's default "authenticated" — that value would let any Supabase
# user JWT access this MCP server (RFC 8707 confused-deputy risk).
ALLOWED_AUDIENCE=https://mcp.calming-paws.com

# --- Issuer claim expected in access tokens ---
# Must match the `iss` claim in the JWT.
# Example: https://<project-ref>.supabase.co/auth/v1
ALLOWED_ISSUER=https://<project-ref>.supabase.co/auth/v1

# --- Supabase data plane (for tool handlers wired to real tables) ---
# REQUIRED for log_walk and get_progress. Tool handlers act as the calling user
# (their JWT is forwarded), so RLS policies apply.
# Example: https://<project-ref>.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co
# The Supabase anon (publishable) key. Safe to expose; combined with the user's
# JWT, RLS gates all access. Do NOT use the service-role key here — it bypasses
# RLS and would defeat the user-scoped authorization model.
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- BYO JWT long-lived service token (optional) ---
# If you issue your own long-lived service tokens (e.g. for server-to-server
# integrations), set the shared HS256 secret here.
# Leave blank to disable the BYO JWT path.
BYO_JWT_SECRET=

# --- CORS: comma-separated list of allowed origins ---
# Example: https://calming-paws.com,https://app.calming-paws.com
ALLOWED_ORIGINS=https://calming-paws.com

# --- Rate limiting (in-memory, scaffold only) ---
# Max requests per hour for unauthenticated demo callers (per IP).
DEMO_RATE_LIMIT_PER_HOUR=20
# Max requests per hour for authenticated users.
AUTH_RATE_LIMIT_PER_HOUR=200
